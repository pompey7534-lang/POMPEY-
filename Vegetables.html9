<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>POMPEY Fresh Vegetables</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f5f5f5;
}

/* Header */

header{
background:#131921;
color:white;
padding:15px 20px;
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
position:sticky;
top:0;
z-index:1000;
}

.logo{
font-size:30px;
font-weight:bold;
color:#00e676;
}

.search-box{
flex:1;
margin:0 20px;
}

.search-box input{
width:100%;
padding:12px;
border:none;
border-radius:6px;
font-size:16px;
}

nav a{
color:white;
text-decoration:none;
margin-left:20px;
font-weight:bold;
}

nav a:hover{
color:#00e676;
}

/* Banner */

.banner{
height:280px;
background:url("https://images.unsplash.com/photo-1542838132-92c53300491e?w=1400") center/cover;
display:flex;
justify-content:center;
align-items:center;
color:white;
font-size:42px;
font-weight:bold;
text-shadow:2px 2px 8px black;
}

/* Products */

.container{
width:95%;
margin:30px auto;
display:grid;
grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
gap:20px;
}

.product{

background:white;

border-radius:12px;

overflow:hidden;

box-shadow:0 5px 15px rgba(0,0,0,.1);

transition:.3s;

text-align:center;

padding-bottom:15px;

position:relative;

}

.product:hover{

transform:translateY(-6px);

}

.product img{

width:100%;

height:180px;

object-fit:cover;

}

.product h3{

margin:10px;

}

.price{

font-size:22px;

color:#0d6efd;

font-weight:bold;

}

.old{

text-decoration:line-through;

color:#888;

font-size:14px;

}

button{

width:90%;

padding:12px;

background:#00c853;

color:white;

border:none;

border-radius:6px;

cursor:pointer;

margin-top:10px;

font-size:16px;

}

button:hover{

background:#009624;

}

.badge{

position:absolute;

left:10px;

top:10px;

background:red;

color:white;

padding:5px 10px;

border-radius:20px;

font-size:12px;

}

.cartCount{

background:red;

padding:3px 8px;

border-radius:50%;

margin-left:5px;

}
// Update floating cart count
document.getElementById("floatingCartCount").innerHTML = cart.length;

// Wishlist heart
function toggleHeart(element) {
    element.classList.toggle("active");
  }
  const sort = document.getElementById("sort");

sort.addEventListener("change", function(){

let container = document.querySelector(".container");

let products = Array.from(document.querySelectorAll(".product"));

products.sort((a,b)=>{

let priceA = parseFloat(a.querySelector(".price").innerText.replace("₹",""));
let priceB = parseFloat(b.querySelector(".price").innerText.replace("₹",""));

if(this.value==="low") return priceA-priceB;

if(this.value==="high") return priceB-priceA;

if(this.value==="name"){
return a.querySelector("h3").innerText.localeCompare(
b.querySelector("h3").innerText);
}

return 0;

});

products.forEach(product=>container.appendChild(product));

});
  
@media(max-width:768px){

header{

flex-direction:column;

gap:15px;

}

.search-box{

width:100%;

margin:0;

}

.banner{

height:180px;

font-size:28px;

}

}
/* Floating Cart */

.floating-cart{
position:fixed;
bottom:20px;
right:20px;
background:#ff9800;
color:white;
padding:15px 20px;
border-radius:50px;
text-decoration:none;
font-size:20px;
font-weight:bold;
box-shadow:0 5px 15px rgba(0,0,0,.3);
z-index:999;
transition:.3s;
}

.floating-cart:hover{
background:#ff6f00;
transform:scale(1.08);
}

/* Heart */

.heart{
position:absolute;
top:10px;
right:10px;
font-size:22px;
color:#bbb;
cursor:pointer;
}

.heart.active{
color:red;
  }
  .top-bar{
display:flex;
gap:15px;
padding:20px;
background:white;
margin:20px;
border-radius:10px;
box-shadow:0 2px 10px rgba(0,0,0,.1);
flex-wrap:wrap;
}

#search{
flex:1;
padding:12px;
font-size:16px;
border:1px solid #ccc;
border-radius:8px;
}

#sort{
padding:12px;
font-size:16px;
border-radius:8px;
border:1px solid #ccc;
cursor:pointer;
  }
  
</style>

</head>

